# Backend key for Google Places + Directions + Geocoding proxy endpoints
GOOGLE_MAPS_SERVER_API_KEY=your_google_maps_server_key_here

# Google Text-to-Speech API key (defaults to GOOGLE_MAPS_SERVER_API_KEY if not set)
GOOGLE_TTS_API_KEY=your_google_tts_key_here

# Groq API key for LLM and audio transcription
GROQ_API_KEY=your_groq_api_key_here

# Database config (Railway will auto-set these)
MAPPLIFY_DB_URL=jdbc:mysql://localhost:3306/mapplify?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MAPPLIFY_DB_USER=root
MAPPLIFY_DB_PASSWORD=your_db_password_here
