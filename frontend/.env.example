# Google Maps JavaScript API key (required for map rendering)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps map ID (optional — use DEMO_MAP_ID for development)
VITE_GOOGLE_MAP_ID=DEMO_MAP_ID

# Backend API base URL (leave empty for same-origin in production)
VITE_API_BASE_URL=http://localhost:8081

# Optional: search debounce in milliseconds
VITE_SEARCH_DEBOUNCE_MS=700
