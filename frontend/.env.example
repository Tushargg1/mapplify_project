# Google Maps browser API key used by @vis.gl/react-google-maps.
# Restrict this key by allowed URLs and enabled APIs in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key_here

# Optional cloud map style id for AdvancedMarker support (default DEMO_MAP_ID).
# VITE_GOOGLE_MAP_ID=your_google_map_id

# Optional: backend base URL for production (leave empty in local dev with Vite proxy)
# VITE_API_BASE_URL=https://your-backend-domain.com
